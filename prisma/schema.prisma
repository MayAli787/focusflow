generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NextAuth.js Models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Application Models
// ==========================================

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String?  @unique
  emailVerified   DateTime?
  image           String?
  healthPoints    Int      @default(0)
  onboardingDone  Boolean  @default(false)
  defaultConfig   Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  studySessions   StudySession[]
  videoWatches    VideoWatch[]
  userBadges      UserBadge[]
  weeklyReports   WeeklyReport[]
  pointTransactions PointTransaction[]
}

enum SessionStatus {
  active
  completed
  abandoned
}

model StudySession {
  id                  String        @id @default(cuid())
  userId              String
  name                String?
  plannedDurationMin  Int
  sessionsPlanned     Int
  sessionsCompleted   Int           @default(0)
  status              SessionStatus @default(active)
  startedAt           DateTime      @default(now())
  endedAt             DateTime?

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycles              StudyCycle[]

  @@index([userId, status])
}

enum CognitiveState {
  focused
  tired
  stressed
}

model StudyCycle {
  id               String          @id @default(cuid())
  sessionId        String
  cycleNumber      Int
  durationMin      Int
  cognitiveState   CognitiveState?
  missionId        String?
  missionCompleted Boolean         @default(false)
  startedAt        DateTime        @default(now())
  endedAt          DateTime?

  session          StudySession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mission          HealthMission?  @relation(fields: [missionId], references: [id])

  @@index([sessionId])
}

enum MissionCategory {
  hydration
  eye_rest
  stretch
  breathing
  movement
}

model HealthMission {
  id          String          @id @default(cuid())
  category    MissionCategory
  title       String
  description String          @db.Text
  videoUrl    String?
  points      Int             @default(10)

  cycles      StudyCycle[]
  videoWatches VideoWatch[]
}

model VideoWatch {
  id          String   @id @default(cuid())
  userId      String
  missionId   String
  sessionId   String?
  completed   Boolean  @default(false)
  pointsGiven Int      @default(0)
  watchedAt   DateTime @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission     HealthMission @relation(fields: [missionId], references: [id])

  @@index([userId])
}

model Badge {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  icon           String
  conditionType  String
  conditionValue Int

  userBadges     UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

model WeeklyReport {
  id                String   @id @default(cuid())
  userId            String
  weekStart         DateTime @db.Date
  weekEnd           DateTime @db.Date
  totalHours        Decimal  @db.Decimal(5, 2)
  missionsCompleted Int      @default(0)
  missionsSkipped   Int      @default(0)
  reportData        Json?
  insights          Json?
  generatedAt       DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
